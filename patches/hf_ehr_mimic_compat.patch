+def _plain_metadata(value: Any) -> Any:
+    if OmegaConf.is_config(value):
+        return OmegaConf.to_container(value, resolve=True, enum_to_str=True)
+    if isinstance(value, dict):
+        return {key: _plain_metadata(val) for key, val in value.items()}
+    if isinstance(value, (list, tuple)):
+        return [_plain_metadata(val) for val in value]
+    return value
+
+
+def _stat_value(stat: Any) -> Optional[float]:
+    if stat is None:
+        return None
+    if isinstance(stat, (int, float)):
+        return float(stat)
+    for attr in ("count", "ppl", "value"):
+        value = getattr(stat, attr, None)
+        if value is not None:
+            try:
+                return float(value)
+            except (TypeError, ValueError):
+                return None
+    return None
+
+
+
+def _load_metadata_json(path: str) -> Optional[Dict[str, Any]]:
+    try:
+        return json.load(open(path, 'r'))
+    except (json.JSONDecodeError, FileNotFoundError):
+        return None
+
+
